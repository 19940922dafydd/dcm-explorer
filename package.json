{
    "name": "dcm-explorer",
    "version": "1.0.0",
    "description": "本地 DICOM 文件检索工具",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder --win",
        "build-mac": "electron-builder --mac",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1"
    },
    "build": {
        "appId": "com.antigravity.dcmexplorer",
        "productName": "DCM资源管家",
        "win": {
            "target": "portable",
            "artifactName": "DCM资源管家_${version}.exe"
        },
        "mac": {
            "target": "dmg",
            "category": "public.app-category.medicine",
            "artifactName": "DCM资源管家_${version}.dmg"
        },
        "directories": {
            "output": "dist"
        }
    }
}